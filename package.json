{
  "name": "toollang-media",
  "version": "1.0.0",
  "description": "Media Studio - Douyin & TikTok Downloader",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:exe": "npm run build && electron-builder --publish always",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "srt-parser-2": "^1.2.1",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.14.0",
    "electron-updater": "^6.8.3",
    "firebase": "^12.11.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5"
  },
  "build": {
    "appId": "com.toollang.media",
    "productName": "ToolLang Media",
    "directories": {
      "output": "build_output"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "forte2000",
        "repo": "Tool-Lang"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "${productName}_v${version}_Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ToolLang Media"
    }
  }
}
